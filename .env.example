# ─────────────────────────────────────────────
# FinSight Agent — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores obrigatórios.
# Variáveis sem valor são OBRIGATÓRIAS — a aplicação não sobe sem elas.
# Variáveis com valor são OPCIONAIS — o default funciona em desenvolvimento.
# ─────────────────────────────────────────────


# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
# OBRIGATÓRIO — sem isso, nenhum agente funciona
OPENAI_API_KEY=

# Modelos separados por ambiente: dev usa mini (mais barato), prod usa 4o (mais capaz)
# Você pode sobrescrever localmente sem alterar o código
OPENAI_MODEL_DEV=gpt-4o-mini
OPENAI_MODEL_PROD=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Limite de custo por query em USD — o agente aborta se exceder (proteção contra loops)
OPENAI_MAX_COST_PER_QUERY_USD=0.10


# ─────────────────────────────────────────────
# Tavily (web search)
# ─────────────────────────────────────────────
# OBRIGATÓRIO para o Research Agent funcionar
# Plano gratuito: 1000 searches/mês — suficiente para dev
TAVILY_API_KEY=


# ─────────────────────────────────────────────
# LangSmith (tracing)
# ─────────────────────────────────────────────
# OPCIONAL — sem isso, tracing é desabilitado silenciosamente (não quebra)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=finsight-agent-dev
# LANGCHAIN_ENDPOINT padrão já é https://api.smith.langchain.com
# só mude se estiver usando self-hosted LangSmith


# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
# DEPLOY (Semana 8): em produção (Fly + Supabase), defina DATABASE_URL com a connection
# string que o Supabase mostra. Quando setada, ela VENCE as partes POSTGRES_* abaixo e
# o app injeta o driver (+asyncpg/+psycopg2) e TLS automaticamente. Em dev local, deixe
# DATABASE_URL vazio e use as partes (batem com o docker-compose.yml).
# Use o "Session pooler" (porta 5432), não o "Transaction pooler" (6543): o app usa
# asyncpg com prepared statements, que quebram no pooler em modo transação. Senha SÓ
# alfanumérica (@ : / ? quebram o parse da URL).
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Valores default batem com o docker-compose.yml — funciona direto com `docker compose up`
POSTGRES_USER=finsight
POSTGRES_PASSWORD=finsight
POSTGRES_DB=finsight
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Pool de conexões async — ajuste conforme carga esperada
# min_size: conexões abertas na inicialização (warm pool)
# max_size: limite máximo (sem overflow, aguarda fila)
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10


# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
# DEPLOY (Semana 8): em produção (Upstash), defina REDIS_URL com a string `rediss://`
# (TLS) que a Upstash fornece. Quando setada, vence as partes REDIS_* abaixo. Em dev,
# deixe vazio e use as partes (batem com o docker-compose.yml).
# REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379
REDIS_URL=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TTL do cache de queries em segundos (default: 1h)
# Queries idênticas dentro deste janela retornam do cache sem chamar os agentes
REDIS_CACHE_TTL_SECONDS=3600


# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ENVIRONMENT controla qual OPENAI_MODEL_* usar e o nível de logging
# Valores válidos: development | staging | production
ENVIRONMENT=development

# SECRET_KEY — usada para assinar tokens internos (não é auth de usuário neste projeto)
# Em dev pode ser qualquer string; em produção use: openssl rand -hex 32
SECRET_KEY=dev-insecure-secret-change-in-production

# CORS: origens permitidas (separadas por vírgula)
# Em dev libera localhost; em produção especifique o domínio do frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:8080


# ─────────────────────────────────────────────
# Ingestion
# ─────────────────────────────────────────────
# Tamanho do chunk em tokens (não caracteres) — respeita limite de contexto do LLM
CHUNK_SIZE_TOKENS=512
# Overlap entre chunks: garante que frases no limite entre chunks apareçam em ambos
# Importante para RAG — sem overlap, contexto é perdido nas bordas
CHUNK_OVERLAP_TOKENS=64
# Batch size para embeddings: OpenAI aceita até 2048 inputs por request
# 100 é um bom trade-off entre throughput e latência de request individual
EMBEDDING_BATCH_SIZE=100


# ─────────────────────────────────────────────
# Prometheus
# ─────────────────────────────────────────────
# Habilita exposição de /metrics — desabilite se não quiser Prometheus em dev
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics


# ─────────────────────────────────────────────
# Eval (avaliação de RAG — métricas próprias, ver evals/metrics.py)
# ─────────────────────────────────────────────
# Thresholds mínimos para o CI não bloquear o merge
EVAL_MIN_FAITHFULNESS=0.75
EVAL_MIN_ANSWER_RELEVANCY=0.70
EVAL_MIN_CONTEXT_RECALL=0.65
